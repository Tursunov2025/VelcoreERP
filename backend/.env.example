# Copy to .env (never commit real secrets)

# Production data outside application folder
DATA_ROOT=D:\AzmusERP\Data
DB_PATH=D:\AzmusERP\Data\database\azmus.db
UPLOAD_PATH=D:\AzmusERP\Data\uploads
SKIP_DEMO_SEED=true
UPLOAD_PATH=D:\AzmusERP\Data\uploads
BACKUP_PATH=D:\AzmusERP\Data\backups
LOG_PATH=D:\AzmusERP\Data\logs
MIGRATION_BACKUP_PATH=D:\AzmusERP\Data\migrations

# Production database guard — fail startup if DB missing/empty/wrong path
DATABASE_GUARD=true
SKIP_DEMO_SEED=true

# Phase 9/10 — disabled by default (UI hidden; APIs remain registered)
TRACEABILITY_ENABLED=false
PRINT_AGENT_ENABLED=false

JWT_SECRET_KEY=change-me-in-production
CORS_ORIGINS=*
AUTO_BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=30
BACKUP_HOUR=2
BACKUP_MINUTE=0
