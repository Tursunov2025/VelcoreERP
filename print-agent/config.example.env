# Azmus Cloud Print Agent — copy to .env and edit

AZMUS_API_URL=https://azmus-crm.onrender.com
PRINT_AGENT_API_KEY=your-secret-agent-key-from-render-env

# Must match printer "name" in ERP Settings → Printers
PRINTER_NAME=XPrinter XP-350B

# Windows printer name (Control Panel → Devices and Printers)
WINDOWS_PRINTER_NAME=XPrinter XP-350B

POLL_INTERVAL_SECONDS=5
AGENT_VERSION=1.0.0
