# Velcore ERP — VPS production environment
# Install: /etc/azmus/.env (chmod 600, owner root:azmus)

ENVIRONMENT=production
DATA_ROOT=/var/lib/azmus/data
UPLOAD_PATH=/var/lib/azmus/data/uploads
BACKUP_PATH=/var/lib/azmus/data/backups
LOG_PATH=/var/lib/azmus/data/logs
MIGRATION_BACKUP_PATH=/var/lib/azmus/data/migrations

DATABASE_URL=postgresql+psycopg2://azmus_app:CHANGE_ME@127.0.0.1:5432/azmus_erp

JWT_SECRET_KEY=CHANGE_ME_64_CHAR_RANDOM
CORS_ORIGINS=https://erp.azmus.uz

HOST=127.0.0.1
PORT=8000
DATABASE_GUARD=false
SKIP_DEMO_SEED=true

AUTO_BACKUP_ENABLED=true
BACKUP_HOUR=2
BACKUP_MINUTE=0
BACKUP_RETENTION_DAYS=30
BACKUP_INCLUDE_UPLOADS=true
REMINDER_TIMEZONE=Asia/Tashkent
REMINDER_HOUR=9
REMINDER_MINUTE=0

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
APP_URL=https://erp.azmus.uz

# Healthcheck script reads these
HEALTHCHECK_API_URL=https://api.azmus.uz/
HEALTHCHECK_UI_URL=https://erp.azmus.uz/
