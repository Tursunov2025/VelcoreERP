# Velcore ERP — VPS production environment
# Install: /etc/velcore/.env (chmod 600)

ENVIRONMENT=production
AZMUS_ENV_FILE=/etc/velcore/.env

DATA_ROOT=/var/lib/velcore/data
UPLOAD_PATH=/var/lib/velcore/data/uploads
BACKUP_PATH=/var/lib/velcore/data/backups
LOG_PATH=/var/lib/velcore/data/logs
MIGRATION_BACKUP_PATH=/var/lib/velcore/data/migrations

DATABASE_URL=postgresql+psycopg2://azmus:CHANGE_ME@127.0.0.1:5432/azmus_erp

JWT_SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_32
CORS_ORIGINS=https://erp.velcore.uz

HOST=127.0.0.1
PORT=8000
DATABASE_GUARD=false
SKIP_DEMO_SEED=true

AUTO_BACKUP_ENABLED=true
BACKUP_HOUR=2
BACKUP_MINUTE=0
BACKUP_RETENTION_DAYS=30
BACKUP_INCLUDE_UPLOADS=true
REMINDER_TIMEZONE=Asia/Tashkent
REMINDER_HOUR=9
REMINDER_MINUTE=0

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
APP_URL=https://erp.velcore.uz

HEALTHCHECK_API_URL=https://api.velcore.uz/
HEALTHCHECK_UI_URL=https://erp.velcore.uz/
