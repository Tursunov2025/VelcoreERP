# Azmus ERP — Production environment (copy to D:\AzmusERP\Application\.env)
# NEVER commit real JWT_SECRET_KEY to git.

# --- Data (outside application folder) ---
DATA_ROOT=D:\AzmusERP\Data
DB_PATH=D:\AzmusERP\Data\database\azmus.db
UPLOAD_PATH=D:\AzmusERP\Data\uploads
BACKUP_PATH=D:\AzmusERP\Data\backups
LOG_PATH=D:\AzmusERP\Data\logs
MIGRATION_BACKUP_PATH=D:\AzmusERP\Data\migrations

# Optional override (auto-built from DB_PATH if empty)
# DATABASE_URL=sqlite:///D:/AzmusERP/Data/database/azmus.db

# --- Security ---
JWT_SECRET_KEY=CHANGE_ME_TO_LONG_RANDOM_SECRET
# Production: explicit origin. Never use * on public VPS.
CORS_ORIGINS=https://erp.velcore.uz
CORS_ALLOW_DEV=true

# --- Server ---
ENVIRONMENT=production
HOST=0.0.0.0
PORT=8000
SQLITE_TIMEOUT_SECONDS=30

# --- Schedulers ---
AUTO_BACKUP_ENABLED=true
BACKUP_HOUR=2
BACKUP_MINUTE=0
BACKUP_RETENTION_DAYS=30
BACKUP_INCLUDE_UPLOADS=true
REMINDER_TIMEZONE=Asia/Tashkent
REMINDER_HOUR=9
REMINDER_MINUTE=0

# --- Telegram (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Frontend build (set before npm run build / APK) ---
# VITE_API_URL=http://192.168.1.100:8000
